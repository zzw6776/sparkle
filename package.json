    "@heroui/react": "2.8.10",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/crypto-js": "^4.2.2",
    "@uruhalushia/sparkle-native": "^0.1.1",
    "adm-zip": "^0.6.0",
    "age-encryption": "^0.3.0",
    "axios": "^1.18.1",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.21",
    "express": "^5.2.1",
    "iconv-lite": "^0.7.3",
    "is-cidr": "^7.0.0",
    "is-ip": "^5.0.1",
    "js-yaml": "^5.2.1",
    "monaco-editor": "^0.55.1",
    "qrcode.react": "^4.2.0",
    "webdav": "^5.10.0",
    "ws": "^8.21.0",
    "yaml": "^2.9.0"
