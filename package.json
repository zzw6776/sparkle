    "electron-vite": "^6.0.0-beta.1",
    "electron-window-state": "^5.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "form-data": "^4.0.6",
    "framer-motion": "12.42.2",
